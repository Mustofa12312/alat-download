{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "VDM",
  "version": "0.1.0",
  "identifier": "com.vdm.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Velocity Download Manager",
        "width": 1024,
        "height": 768,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
